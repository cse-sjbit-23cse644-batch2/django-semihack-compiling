# GradeDNA AI — Local Development Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore so your key is never committed.

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...your-key-here...

# Django secret key (change this for production)
SECRET_KEY=local-dev-secret-key-change-me

# Set to True for local development, False in production
DEBUG=True
